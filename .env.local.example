# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Landing (상담 신청 폼이 있는 외부 랜딩 페이지)
NEXT_PUBLIC_LANDING_URL=https://rebornlabs.vercel.app

# SNS 광고 랜딩 (/apply) — 제출 완료 화면 연결 링크
NEXT_PUBLIC_KAKAO_CHAT_URL=https://open.kakao.com/o/sjk1AUoi
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/reborn_labs_

# Solapi 알림톡 (DEV ONLY — sandbox 모드 강제, 실서비스 발신번호 사용 금지)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_PFID=                       # 카카오 비즈니스 채널 ID (콘솔 발급)
SOLAPI_FROM_NUMBER=                # 발신 번호 (사전 인증 완료된 번호만)
ALIMTALK_SANDBOX_MODE=true         # true → 실제 발송 X, mock 응답. false 는 CTO 명시 승인 후

# 솔라피 콘솔 사전 심사 통과 후 발급되는 templateId (5/4 신청 → 5/5-7 승인 예상)
SOLAPI_TEMPLATE_NEW_TO_ADMIN=
SOLAPI_TEMPLATE_ASSIGNED_TO_DEALER=
SOLAPI_TEMPLATE_TIMEOUT_TO_ADMIN=
SOLAPI_TEMPLATE_CANCELLED_TO_DEALER=

# 알림톡 수신자 — 신규 상담 / 30분 timeout 알림을 받을 운영자 번호
# 콤마로 다수 지정 가능 (예: 01012345678,01098765432). 미설정 시 신규 상담 알림 스킵.
ADMIN_PHONE_NUMBERS=
