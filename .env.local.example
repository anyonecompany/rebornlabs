# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Landing (상담 신청 폼이 있는 외부 랜딩 페이지)
NEXT_PUBLIC_LANDING_URL=https://rebornlabs.vercel.app

# SNS 광고 랜딩 (/apply) — 제출 완료 화면 연결 링크
NEXT_PUBLIC_KAKAO_CHAT_URL=https://open.kakao.com/o/sjk1AUoi
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/reborn_labs_

# 알리고(Aligo) 카카오 알림톡 — 리본랩스 공식 카카오채널 발송
ALIGO_API_KEY=                     # 알리고 콘솔 발급
ALIGO_USER_ID=                     # 알리고 가입 ID
ALIGO_SENDER_KEY=                  # 카카오 발신프로필 senderkey (리본랩스 공식 채널과 매핑)
ALIGO_FROM_NUMBER=                 # 사전 인증된 발신번호 (예: 0211112222)
ALIGO_TEST_MODE=N                  # Y → 실제 발송 안 함 (mock). 운영은 N.

# 사전심사 통과한 템플릿 코드 (알리고 콘솔 발급, 영업일 1~2일)
# 미설정이어도 OK — failover=Y 로 알림톡 거부 시 SMS 자동 대체 발송됨.
ALIGO_TPL_CODE_NEW_TO_ADMIN=
ALIGO_TPL_CODE_ASSIGNED_TO_DEALER=
ALIGO_TPL_CODE_TIMEOUT_TO_ADMIN=
ALIGO_TPL_CODE_CANCELLED_TO_DEALER=

# 알림 수신자 — 신규 상담 / 30분 timeout 알림을 받을 운영자 번호
# 콤마로 다수 지정 가능 (예: 01012345678,01098765432). 미설정 시 신규 상담 알림 스킵.
ADMIN_PHONE_NUMBERS=
